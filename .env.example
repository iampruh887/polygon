# ── Database (required) ──────────────────────────────────
# Supabase Postgres connection string. Use the TRANSACTION pooler
# (Settings → Database → Connection string → Transaction, port 6543) for
# serverless-safe pooling on Vercel. Local dev uses the same variable.
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Polygon uses your own LLM API key, stored locally. Never committed.
# Anthropic (preferred):
ANTHROPIC_API_KEY=sk-ant-...
# Optional override (defaults to https://api.anthropic.com):
# ANTHROPIC_BASE_URL=
# Optional model override (defaults to claude-sonnet-4-6):
# LLM_MODEL=

# Or an OpenAI-compatible endpoint instead:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com

# ── Accounts & community (optional) ──────────────────────
# Without these, Polygon runs in solo mode: local-first, no sign-in.
# To enable Google sign-in + the Commons: create a free Clerk app at
# https://dashboard.clerk.com, enable the Google social connection,
# then paste both keys here and restart.
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
